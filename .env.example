# Copy this file to ".env" and fill in real values.
# .env is loaded automatically by config.py (python-dotenv) and should
# NEVER be committed to version control.

# A long random string - e.g. generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-string

# Leave DATABASE_URL unset to use the default local SQLite file at
# instance/games_meetup.db
# DATABASE_URL=sqlite:////absolute/path/to/games_meetup.db

# --- Email (used for password reset + listing notifications) ---------------
# Example using a free Gmail account + "App Password"
# (Google Account > Security > 2-Step Verification > App passwords):
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your_address@gmail.com
MAIL_PASSWORD=your_16_char_app_password
MAIL_DEFAULT_SENDER=your_address@gmail.com

# Set to "true" to disable real email sending (prints to console instead)
MAIL_SUPPRESS_SEND=false

# --- Business rules ----------------------------------------------------------
AUTO_CLOSE_AFTER_DAYS=3
SCHEDULER_INTERVAL_MINUTES=60

# The first person to register with this email becomes an admin
# automatically. If left blank, the very first user to ever register
# becomes admin instead.
INITIAL_ADMIN_EMAIL=
